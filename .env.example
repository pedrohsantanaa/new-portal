# ===========================================
# Portal de Credito - Variaveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# Senha do banco PostgreSQL (use a mesma no .env do backend)
DB_PASSWORD=CHANGE-ME-SENHA-FORTE

# Chave secreta para JWT (gere uma aleatoria com 64+ caracteres)
SECRET_KEY=CHANGE-ME-CHAVE-ALEATORIA

# Dominio do site (sem https://)
ALLOWED_ORIGINS=http://localhost
