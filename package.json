  "dependencies": {
    "axios": "^1.18.0",
    "dompurify": "^3.4.11",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "swiper": "^12.1.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vite": "^8.0.12"
  }
}
