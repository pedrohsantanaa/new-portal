{
  "name": "new-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:admin": "cd admin && npm run dev",
